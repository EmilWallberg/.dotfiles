{
    "name": "",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh"
    },
    "mounts": [
        "source=${env:HOME}/.local/share/nvim,target=/home//.local/share/nvim,type=bind,consistency=cached",
        "source=${env:HOME}/.local/share/opencode,target=/home//.local/share/opencode,type=bind,consistency=cached",
        "source=${env:HOME}/.config/nvim,target=/home//.config/nvim,type=bind,consistency=cached",
        "source=${env:HOME}/.config/zsh,target=/home//.config/zsh,type=bind,consistency=cached",
        "source=${env:HOME}/.config/tmux,target=/home//.config/tmux,type=bind,consistency=cached",
        "source=${env:HOME}/.config/opencode,target=/home//.config/opencode,type=bind,consistency=cached",
        "source=${env:HOME}/.gitconfig,target=/home//.gitconfig,type=bind,readonly",
        "source=${env:HOME}/.gitconfig_local,target=/home//.gitconfig_local,type=bind,readonly",
        "source=${env:HOME}/.zshrc,target=/home//.zshrc,type=bind,readonly",
    ],
    "containerEnv": {
        "LLAMACPP_URL": "",
        "LLAMACPP_API_KEY": "",
        "LLAMACPP_MODEL_ALIAS": "",
        "OPENCODE_PROVIDER_ID": "",
        "OPENCODE_MODEL": "",
        "OPENCODE_SMALL_MODEL": "",
        "SHELL": "/usr/bin/zsh"
    },
    // Essential for Linux to resolve host.docker.internal
    "runArgs": [
        "--network=llm-net"
    ],
    "postCreateCommand": "bash .devcontainer/post-create.sh",
    "remoteUser": ""
}
