# Global Settings
max-history=5
sort=-time

# Appearance
font=monospace 10
width=300
height=100
margin=20
padding=15
border-size=2
border-radius=8

# Colors (Nord/Grayish Style)
background-color=#1e1e2e
text-color=#cdd6f4
border-color=#89b4fa
progress-color=over #313244

# Speed of disappearance (3000ms = 3 seconds)
default-timeout=3000

[urgency=high]
border-color=#f38ba8
# 0 means the notification stays until you click it
default-timeout=0
