{
    "$schema": "https://opencode.ai/config.json",
    "model": "{env:OPENCODE_MODEL}",
    "small_model": "{env:OPENCODE_SMALL_MODEL}",
    "plugin": [
        "opencode-websearch",
        "caveman",
        "opencode-large-image-optimizer@latest"
    ],
    "provider": {
        "llama-local": {
            "name": "Llama.cpp (RTX5080)",
            "npm": "@ai-sdk/openai-compatible",
            "options": {
                "baseURL": "{env:LLAMACPP_URL}",
                "apiKey": "{env:LLAMACPP_API_KEY}",
                "websearch": "auto"
            },
            "models": {
                "local-model": {
                    "name": "Local Model"
                }
            }
        }
    }
}
